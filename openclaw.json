{
  "agent": {
    "model": "google/gemini-2.0-flash",
    "models": {
      "google": {
        "apiKey": "${GEMINI_API_KEY}"
      },
      "deepseek": {
        "apiKey": "${DEEPSEEK_API_KEY}"
      }
    }
  },
  "gateway": {
    "port": 8080,
    "bind": "lan"
  },
  "channels": {
    "telegram": {
      "botToken": "${TELEGRAM_BOT_TOKEN}"
    }
  },
  "modelFailover": [
    "gemini-3.1-flash-lite-preview",
    "deepseek/deepseek-chat"
  ]
}
